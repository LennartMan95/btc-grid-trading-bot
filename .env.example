# Vorlage fuer .env — echte Werte NUR in .env eintragen (nie committen!).
# Kopieren:  cp .env.example .env  und die Platzhalter ersetzen.

# Alpaca API-Keys (Paper-Trading-Keys von https://app.alpaca.markets/).
ALPACA_API_KEY=dein_paper_api_key
ALPACA_SECRET_KEY=dein_paper_secret_key

# Sicherheitsschalter: True = Paper-Trading (Pflicht fuer diese Abgabe).
ALPACA_PAPER=True
